from flask import Flask, render_template, request
from pymongo import MongoClient

app = Flask(__name__, template_folder="templates")

# MongoDB
MONGO_URI = "mongodb+srv://rudanimili1118_db_user:MiliRudani1234@cluster0.vweh5lh.mongodb.net/?appName=Cluster0"
client = MongoClient(MONGO_URI)
db = client["apkonic"]
users = db["users"]

@app.route("/")
def home():
    return render_template("index.html")

@app.route("/register", methods=["POST"])
def register():
    name = request.form.get("name")
    email = request.form.get("email")
    password = request.form.get("password")

    users.insert_one({
        "name": name,
        "email": email,
        "password": password
    })

    return render_template("index.html", message="User registered successfully")

if __name__ == "__main__":
    app.run(debug=True, port=10000)



function scanSMS() {
    const sms = document.getElementById("smsBox").value;

    fetch("https://apkonic-fdyt.onrender.com/scan-sms", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            content: sms
        })
    })
    .then(response => response.json())
    .then(data => {
        const result = document.getElementById("resultText");

        if (data.result === "fake") {
            result.innerHTML = "⚠️ Fake / Phishing SMS Detected";
            result.style.color = "red";
        } else {
            result.innerHTML = "✅ SMS is Safe";
            result.style.color = "green";
        }
    })
    .catch(error => {
        alert("Backend connection failed");
        console.log(error);
    });
}


