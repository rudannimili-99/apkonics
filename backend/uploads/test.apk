<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Apkonic - APK & Smishing Detection</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Arial, sans-serif;
}

body{
  background:#f4f7fb;
}

/* Navbar */
header{
  background:#0a1931;
  color:white;
  padding:15px 50px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.logo{
  font-size:22px;
  font-weight:bold;
}

nav a{
  color:white;
  text-decoration:none;
  margin-left:20px;
  font-size:16px;
}

nav a:hover{
  color:#00c3ff;
}

/* Hero Section */
.hero{
  height:80vh;
  background:linear-gradient(to right,#0a1931,#1f3c88);
  color:white;
  text-align:center;
  padding-top:150px;
}

.hero h1{
  font-size:40px;
  margin-bottom:20px;
}

.hero p{
  font-size:18px;
  margin-bottom:30px;
}

.hero button{
  padding:12px 25px;
  border:none;
  background:#00c3ff;
  color:black;
  font-size:16px;
  border-radius:5px;
  cursor:pointer;
}

.hero button:hover{
  background:#00aaff;
}

/* Scan Section */
.scan{
  padding:60px 50px;
  text-align:center;
}

.scan h2{
  margin-bottom:40px;
}

.scan-box{
  display:flex;
  justify-content:center;
  gap:30px;
  flex-wrap: wrap;
}

.card{
  background:white;
  padding:25px;
  width:300px;
  border-radius:10px;
  box-shadow:0 0 10px rgba(0,0,0,0.1);
}

.card h3{
  margin-bottom:15px;
}

.card input,
.card textarea{
  width:100%;
  padding:10px;
  margin-bottom:15px;
  border-radius:5px;
  border:1px solid #ccc;
}

.card button{
  padding:10px 20px;
  background:#1f3c88;
  color:white;
  border:none;
  border-radius:5px;
  cursor:pointer;
}

.card button:hover{
  background:#0a1931;
}

/* Features */
.features{
  background:#e3f2fd;
  padding:60px 50px;
  text-align:center;
}

.feature-box{
  display:flex;
  justify-content:center;
  gap:20px;
}

.feature{
  background:white;
  padding:20px;
  border-radius:10px;
  width:200px;
  box-shadow:0 0 10px rgba(0,0,0,0.1);
  font-size:16px;
}

/* About */
.about{
  padding:60px 50px;
  text-align:center;
}

.about p{
  max-width:700px;
  margin:auto;
  line-height:1.6;
}

/* Footer */
footer{
  background:#0a1931;
  color:white;
  text-align:center;
  padding:15px;
  margin-top:20px;
}

/* Responsive */
@media(max-width:768px){
  .scan-box,
  .feature-box{
    flex-direction:column;
    align-items:center;
  }

  .hero{
    padding-top:100px;
  }
}
</style>
</head>

<body>

<header>
  <div class="logo">Apkonic</div>
  <nav>
    <a href="#home">Home</a>
    <a href="/scan">Scan</a>
    <a href="/features">Features</a>
    <a href="/aboutus">About</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<section class="hero" id="home">
  <h1>Detect Fraudulent APK & Smishing Attacks</h1>
  <p>Protect yourself from malicious apps and scam messages with Apkonic intelligent detection system.</p>
  <button>Get Started</button>
</section>
</div>
</section>

<script src="{{ url_for('static', filename='script.js') }}"></script>
</body>
</html>
